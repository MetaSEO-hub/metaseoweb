---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const phases = [
  {
    number: '01',
    title: 'Research Semántico',
    subtitle: 'La base de todo',
    description: 'Identificamos la entidad central de tu negocio, todos sus atributos (root, rare, unique) y las intenciones de búsqueda reales de tus potenciales clientes. Sin datos reales, no hay estrategia válida.',
    deliverables: ['Entidad central definida', 'Atributos categorizados', '200-500 keywords analizadas', 'Análisis de competidores top 10', 'Mapa de intenciones'],
  },
  {
    number: '02',
    title: 'Mapa Tópico',
    subtitle: 'La arquitectura de autoridad',
    description: 'Diseñamos la estructura completa de contenidos siguiendo la metodología Hub-Cluster-Leaf. Definimos las secciones Core (monetización) y Author (autoridad), y priorizamos los nodos de calidad.',
    deliverables: ['Hub principal definido', 'Clusters temáticos', 'Hojas de soporte', 'Nodos de calidad (top 5)', 'Mapa de enlazado interno'],
  },
  {
    number: '03',
    title: 'Briefs de Contenido',
    subtitle: 'La semántica aplicada',
    description: 'Para cada página clave, creamos un brief detallado con vector contextual (predicados + sustantivos), estructura de headings, microsemantics y especificaciones de formato. El contenido que crea autoridad.',
    deliverables: ['Vector contextual por página', 'Estructura H1-H4 optimizada', 'Especificación de formatos', 'Instrucciones de microsemantics', 'Plan de enlazado'],
  },
  {
    number: '04',
    title: 'Auditoría Continua',
    subtitle: 'El control de calidad',
    description: 'Sistema de puntuación de 100 puntos con verificación E-A-V (Entidad-Atributo-Valor) y análisis de modalidad (is/can/may). Cada contenido publicado pasa por nuestro sistema de auditoría antes y después de publicar.',
    deliverables: ['Score de 100 puntos', 'Verificación E-A-V', 'Análisis de modalidad', 'Checklist pre-publicación', 'Seguimiento post-publicación'],
  },
  {
    number: '05',
    title: 'Linking & Performance',
    subtitle: 'La distribución de autoridad',
    description: 'Construcción de la matriz de enlazado interno con recomendaciones de anchor text optimizadas. Seguimiento de posiciones con Topic Strength Score (TSS) y alertas de canibalización.',
    deliverables: ['Matriz de linking interno', 'Anchor text variations', 'TSS por tema', 'Tracking en tiempo real', 'Detección de canibalización'],
  },
];
---

<Layout
  title="Metodología SEO Semántico | Autoridad Tópica - MetaSEO"
  description="Metodología de SEO Semántico basada en autoridad tópica: Research, Mapa Tópico, Briefs de Contenido, Auditoría y Linking. El proceso que genera resultados sostenibles."
>
  <Header />

  <main>
    <!-- HERO -->
    <section class="relative pt-40 pb-24 grid-bg overflow-hidden">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[400px] rounded-full opacity-5 blur-3xl pointer-events-none" style="background: radial-gradient(circle, #2563EB, #7C3AED, transparent);"></div>

      <div class="mx-auto max-w-7xl px-6 text-center">
        <div class="section-label mx-auto w-fit">Metodología</div>
        <h1 class="text-5xl md:text-6xl font-black tracking-tight mb-6">
          SEO Semántico basado en<br />
          <span class="gradient-text">Autoridad Tópica</span>
        </h1>
        <p class="text-slate-400 text-xl max-w-2xl mx-auto leading-relaxed">
          No hacemos SEO de keywords aisladas. Construimos la autoridad total de tu sitio en tu nicho, usando la metodología más avanzada del mercado: la topical authority.
        </p>
      </div>
    </section>

    <!-- FILOSOFÍA -->
    <section class="py-20 bg-[#0D1117]">
      <div class="mx-auto max-w-7xl px-6">
        <h2 class="text-3xl font-black tracking-tight mb-10 text-center">
          Los tres pilares del <span class="gradient-text">SEO Semántico</span>
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {[
            { icon: '⬡', title: 'Vastness', description: 'Cubrimos todos los tópicos relevantes de tu nicho. Google reconoce la amplitud de cobertura como señal de autoridad.' },
            { icon: '⬇', title: 'Depth', description: 'Profundizamos en cada tema. Un contenido superficial no construye autoridad. La profundidad semántica sí.' },
            { icon: '⟳', title: 'Momentum', description: 'Publicamos consistentemente. Google aprende que tu sitio es la fuente más actualizada y relevante de tu sector.' },
          ].map(p => (
            <div class="card text-center">
              <div class="text-4xl mb-4">{p.icon}</div>
              <h3 class="text-xl font-bold text-white mb-3">{p.title}</h3>
              <p class="text-slate-400 text-sm leading-relaxed">{p.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 5 PHASES -->
    <section class="py-24">
      <div class="mx-auto max-w-5xl px-6">
        <div class="text-center mb-20">
          <div class="section-label mx-auto w-fit">5 Fases</div>
          <h2 class="text-4xl font-black mb-4">El proceso completo</h2>
        </div>

        <div class="space-y-12">
          {phases.map((phase, i) => (
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
              <div class={i % 2 !== 0 ? 'md:order-2' : ''}>
                <div class="flex items-center gap-4 mb-4">
                  <span class="text-5xl font-black" style="background: linear-gradient(135deg, #2563EB, #7C3AED); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">{phase.number}</span>
                  <div>
                    <div class="text-xs text-slate-500 uppercase tracking-wide">{phase.subtitle}</div>
                    <h3 class="text-2xl font-bold text-white">{phase.title}</h3>
                  </div>
                </div>
                <p class="text-slate-400 leading-relaxed">{phase.description}</p>
              </div>
              <div class={`card ${i % 2 !== 0 ? 'md:order-1' : ''}`}>
                <div class="text-xs font-semibold text-blue-400 uppercase tracking-wider mb-3">Deliverables</div>
                <ul class="space-y-2">
                  {phase.deliverables.map(d => (
                    <li class="flex items-center gap-2 text-sm text-slate-300">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                      {d}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-24 bg-[#0D1117]">
      <div class="mx-auto max-w-3xl px-6 text-center">
        <h2 class="text-4xl font-black mb-6">
          Aplica esta metodología<br /><span class="gradient-text">a tu negocio</span>
        </h2>
        <p class="text-slate-400 text-lg mb-10">
          El primer paso es entender tu situación actual. Empieza con una auditoría gratuita.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/servicios/auditoria-seo" class="btn-primary">
            Solicitar auditoría gratuita
          </a>
          <a href="/contacto" class="btn-secondary">
            Hablar con un experto
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
