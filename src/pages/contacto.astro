---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contacto MetaSEO",
  "description": "Contacta con MetaSEO para solicitar auditoría SEO gratuita o propuesta de servicios SEO.",
  "url": "https://metaseo.es/contacto"
};
---

<Layout
  title="Contacto | Solicita tu Propuesta SEO - MetaSEO Córdoba"
  description="Contacta con MetaSEO para solicitar tu auditoría SEO gratuita o una propuesta personalizada. Respuesta en menos de 24 horas. Agencia SEO en Córdoba."
  schema={schema}
>
  <Header />

  <main class="pt-32 pb-24">
    <div class="mx-auto max-w-7xl px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

        <!-- LEFT: Info -->
        <div>
          <div class="section-label">Contacto</div>
          <h1 class="text-5xl md:text-6xl font-black tracking-tight mb-6">
            Hablemos de<br />
            <span class="gradient-text">tu proyecto</span>
          </h1>
          <p class="text-slate-500 text-lg leading-relaxed mb-10">
            Cuéntanos tu situación actual y lo que quieres conseguir. Sin compromiso. Respondemos en menos de 24 horas con un análisis inicial de tu web.
          </p>

          <div class="space-y-6 mb-12">
            {[
              {
                icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
                label: 'Email',
                value: 'hola@metaseo.es',
                href: 'mailto:hola@metaseo.es',
              },
              {
                icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.61 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.08 6.08l1.27-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`,
                label: 'Teléfono',
                value: '+34 600 000 000',
                href: 'tel:+34600000000',
              },
              {
                icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
                label: 'Ubicación',
                value: 'Córdoba, Andalucía, España',
                href: null,
              },
            ].map(c => (
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 text-blue-400" style="background: rgba(37,99,235,0.1); border: 1px solid rgba(37,99,235,0.2);">
                  <Fragment set:html={c.icon} />
                </div>
                <div>
                  <div class="text-slate-500 text-xs uppercase tracking-wide mb-0.5">{c.label}</div>
                  {c.href ? (
                    <a href={c.href} class="text-slate-900 font-medium hover:text-blue-400 transition-colors">{c.value}</a>
                  ) : (
                    <span class="text-slate-900 font-medium">{c.value}</span>
                  )}
                </div>
              </div>
            ))}
          </div>

          <!-- Image -->
          <img
            src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&w=800&q=80"
            alt="Equipo de MetaSEO - agencia SEO en Córdoba listos para ayudarte"
            class="rounded-xl w-full shadow-md border border-slate-100 mb-8"
            loading="lazy"
            width="800"
            height="500"
          />

          <!-- Trust -->
          <div class="card">
            <p class="font-semibold text-slate-900 mb-4">Qué pasa cuando nos contactas</p>
            <ul class="space-y-3">
              {[
                'Revisamos tu web y situación actual (sin coste)',
                'Te respondemos en menos de 24h laborables',
                'Preparamos un análisis inicial personalizado',
                'Si encajamos, te enviamos propuesta detallada',
                'Sin presión. Sin contratos de permanencia forzosa.',
              ].map(item => (
                <li class="flex items-start gap-2 text-sm text-slate-600">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- RIGHT: Form -->
        <div class="card">
          <h2 class="text-xl font-bold text-slate-900 mb-6">Solicita tu análisis gratuito</h2>
          <form
            name="contacto"
            method="POST"
            class="space-y-5"
            novalidate
          >
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="nombre" class="block text-sm font-medium text-slate-600 mb-1.5">Nombre *</label>
                <input
                  type="text"
                  id="nombre"
                  name="nombre"
                  required
                  placeholder="Tu nombre"
                  class="w-full px-4 py-3 rounded-lg text-sm text-slate-900 placeholder-slate-500 border outline-none transition-all focus:border-blue-500"
                  
                />
              </div>
              <div>
                <label for="empresa" class="block text-sm font-medium text-slate-600 mb-1.5">Empresa</label>
                <input
                  type="text"
                  id="empresa"
                  name="empresa"
                  placeholder="Nombre de tu empresa"
                  class="w-full px-4 py-3 rounded-lg text-sm text-slate-900 placeholder-slate-500 border outline-none transition-all focus:border-blue-500"
                  
                />
              </div>
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-slate-600 mb-1.5">Email *</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="tu@empresa.com"
                class="w-full px-4 py-3 rounded-lg text-sm text-slate-900 placeholder-slate-500 border outline-none transition-all focus:border-blue-500"
                
              />
            </div>

            <div>
              <label for="web" class="block text-sm font-medium text-slate-600 mb-1.5">URL de tu web *</label>
              <input
                type="url"
                id="web"
                name="web"
                required
                placeholder="https://tuweb.com"
                class="w-full px-4 py-3 rounded-lg text-sm text-slate-900 placeholder-slate-500 border outline-none transition-all focus:border-blue-500"
                
              />
            </div>

            <div>
              <label for="servicio" class="block text-sm font-medium text-slate-600 mb-1.5">¿Qué necesitas?</label>
              <select
                id="servicio"
                name="servicio"
                class="w-full px-4 py-3 rounded-lg text-sm border outline-none transition-all focus:border-blue-500 appearance-none"
                
              >
                <option value="">Selecciona un servicio...</option>
                <option value="auditoria">Auditoría SEO gratuita</option>
                <option value="seo-local">SEO Local Córdoba</option>
                <option value="posicionamiento">Posicionamiento Web</option>
                <option value="enterprise">SEO para Empresas</option>
                <option value="otro">Otro / No sé aún</option>
              </select>
            </div>

            <div>
              <label for="mensaje" class="block text-sm font-medium text-slate-600 mb-1.5">Cuéntanos tu situación</label>
              <textarea
                id="mensaje"
                name="mensaje"
                rows="4"
                placeholder="¿Cuál es tu principal reto de posicionamiento? ¿Qué has probado antes? ¿Qué resultados buscas?"
                class="w-full px-4 py-3 rounded-lg text-sm text-slate-900 placeholder-slate-500 border outline-none transition-all focus:border-blue-500 resize-none"
                
              ></textarea>
            </div>

            <button type="submit" class="btn-primary w-full justify-center text-base">
              Enviar solicitud
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </button>

            <p class="text-slate-600 text-xs text-center">
              Al enviar aceptas nuestra política de privacidad. Nunca compartimos tus datos.
            </p>
          </form>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  input:focus, textarea:focus, select:focus {
    border-color: #2563EB !important;
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
  }
</style>
