---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const included = [
  { title: 'Mapa Tópico Completo', description: 'Diseñamos la arquitectura Hub-Cluster-Leaf de toda tu web para construir autoridad tópica en tu nicho.' },
  { title: 'Contenido Semántico', description: 'Creación y optimización de contenido con vectores contextuales, microsemantics y estructura E-A-V.' },
  { title: 'SEO Técnico', description: 'Corrección de todos los errores técnicos: velocidad, indexación, schema markup y Core Web Vitals.' },
  { title: 'Link Building', description: 'Estrategia de adquisición de enlaces de calidad relevantes para tu sector y localización.' },
  { title: 'Internal Linking', description: 'Matriz de enlazado interno optimizada para distribuir autoridad y guiar el rastreo de Google.' },
  { title: 'Reporting Mensual', description: 'Dashboard con KPIs claros: posiciones, tráfico, impresiones, CTR y Topic Strength Score (TSS).' },
];
---

<Layout
  title="Posicionamiento Web SEO | Estrategia Integral - MetaSEO Córdoba"
  description="Posicionamiento web integral con enfoque en autoridad tópica y SEO semántico. Estrategia completa: mapa tópico, contenido, links y SEO técnico. Resultados medibles."
>
  <Header />

  <main>
    <!-- HERO -->
    <section class="relative pt-40 pb-24 grid-bg overflow-hidden">
      <div class="absolute top-1/3 right-1/4 w-80 h-80 rounded-full opacity-8 blur-3xl pointer-events-none" style="background: radial-gradient(circle, #2563EB, transparent);"></div>

      <div class="mx-auto max-w-7xl px-6">
        <div class="max-w-3xl">
          <div class="section-label">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            Posicionamiento Web · SEO Integral
          </div>
          <h1 class="text-5xl md:text-6xl font-black tracking-tight mb-6">
            Posicionamiento web<br />
            <span class="gradient-text">sostenible y medible</span>
          </h1>
          <p class="text-slate-500 text-xl leading-relaxed mb-8 max-w-2xl">
            El posicionamiento web real no es hacer keywords sueltas. Es construir la autoridad total de tu sitio en tu sector, para que Google te vea como la fuente definitiva.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/contacto" class="btn-primary">
              Solicitar propuesta SEO
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="/servicios/auditoria-seo" class="btn-secondary">
              Auditoría gratuita primero
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- INCLUDED -->
    <section class="py-24">
      <div class="mx-auto max-w-7xl px-6">
        <div class="text-center mb-16">
          <div class="section-label mx-auto w-fit">Qué incluye</div>
          <h2 class="text-4xl font-black mb-4">
            Todo lo que necesitas<br /><span class="gradient-text">en un solo servicio</span>
          </h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {included.map(item => (
            <div class="card">
              <div class="w-8 h-8 rounded-lg flex items-center justify-center mb-4" style="background: rgba(37,99,235,0.1);">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <h3 class="font-bold text-slate-900 mb-2">{item.title}</h3>
              <p class="text-slate-500 text-sm leading-relaxed">{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- RESULTADOS -->
    <section class="py-20 bg-slate-50">
      <div class="mx-auto max-w-7xl px-6">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-black mb-4">Resultados que puedes esperar</h2>
          <p class="text-slate-500">Basados en proyectos reales. Los resultados varían según sector y competencia.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {[
            { periodo: 'Mes 1-2', titulo: 'Fundaciones sólidas', items: ['Auditoría completa', 'Mapa tópico definido', 'Correcciones técnicas', 'Primeras optimizaciones'] },
            { periodo: 'Mes 3-4', titulo: 'Primeros movimientos', items: ['Keywords en top 20-30', 'Tráfico +30-50%', 'Contenido hub publicado', 'Link building activo'] },
            { periodo: 'Mes 6+', titulo: 'Resultados sostenidos', items: ['Keywords top 5-10', 'Tráfico +150-300%', 'Autoridad tópica establecida', 'Liderazgo en nicho'] },
          ].map(r => (
            <div class="card text-center">
              <div class="text-xs font-bold text-blue-400 uppercase tracking-wider mb-2">{r.periodo}</div>
              <h3 class="text-xl font-bold text-slate-900 mb-4">{r.titulo}</h3>
              <ul class="space-y-2 text-left">
                {r.items.map(item => (
                  <li class="flex items-center gap-2 text-sm text-slate-600">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-24 relative overflow-hidden">
      <div class="absolute inset-0 grid-bg opacity-20"></div>
      <div class="relative mx-auto max-w-3xl px-6 text-center">
        <h2 class="text-4xl md:text-5xl font-black mb-6">
          Empieza a posicionar<br />
          <span class="gradient-text">tu negocio hoy</span>
        </h2>
        <p class="text-slate-500 text-lg mb-8">
          Solicita una propuesta personalizada. Analizamos tu sector y te presentamos una estrategia con proyección de resultados.
        </p>
        <a href="/contacto" class="btn-primary text-base">
          Quiero mi propuesta SEO
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
