---
const services = [
  { href: '/servicios/seo-local-cordoba', label: 'SEO Local Córdoba' },
  { href: '/servicios/auditoria-seo', label: 'Auditoría SEO' },
  { href: '/servicios/posicionamiento-web', label: 'Posicionamiento Web' },
  { href: '/servicios/seo-para-empresas', label: 'SEO para Empresas' },
];

const company = [
  { href: '/metodologia', label: 'Metodología' },
  { href: '/servicios', label: 'Todos los Servicios' },
  { href: '/contacto', label: 'Contacto' },
];
---

<footer class="border-t border-slate-200 bg-slate-50">
  <div class="mx-auto max-w-7xl px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
      <!-- Brand -->
      <div class="md:col-span-2">
        <a href="/" class="flex items-center gap-2 mb-4">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, #2563EB, #10B981);">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <path d="M21 21L16.657 16.657M16.657 16.657A8 8 0 1 0 5.343 5.343a8 8 0 0 0 11.314 11.314Z" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
              <path d="M8 12h4M10 10v4" stroke="white" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </div>
          <span class="font-bold text-xl text-slate-900 tracking-tight">Meta<span class="gradient-text">SEO</span></span>
        </a>
        <p class="text-slate-500 text-sm leading-relaxed max-w-xs mb-6">
          Agencia SEO en Córdoba especializada en autoridad tópica y posicionamiento semántico. Resultados medibles, metodología probada.
        </p>
        <div class="flex flex-col gap-2 text-sm text-slate-500">
          <a href="mailto:hola@metaseo.es" class="hover:text-blue-600 transition-colors flex items-center gap-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            hola@metaseo.es
          </a>
          <a href="tel:+34639589192" class="hover:text-blue-600 transition-colors flex items-center gap-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.61 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.08 6.08l1.27-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            +34 639 589 192
          </a>
          <span class="flex items-center gap-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            Córdoba, España
          </span>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-slate-900 font-semibold text-sm mb-4 uppercase tracking-wide">Servicios</h3>
        <ul class="space-y-3">
          {services.map(link => (
            <li>
              <a href={link.href} class="text-slate-500 text-sm hover:text-blue-600 transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-slate-900 font-semibold text-sm mb-4 uppercase tracking-wide">Empresa</h3>
        <ul class="space-y-3">
          {company.map(link => (
            <li>
              <a href={link.href} class="text-slate-500 text-sm hover:text-blue-600 transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="border-t border-slate-200 mt-12 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-slate-400 text-sm">
        © {new Date().getFullYear()} MetaSEO. Todos los derechos reservados.
      </p>
      <p class="text-slate-300 text-xs">
        Agencia SEO · Córdoba, España
      </p>
    </div>
  </div>
</footer>
